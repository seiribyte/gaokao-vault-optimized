# Database (matches docker-compose defaults)
GAOKAO_DB__DSN=postgresql://gaokao:gaokao@localhost:5432/gaokao_vault
GAOKAO_DB__POOL_MIN=5
GAOKAO_DB__POOL_MAX=20

# Proxy (optional)
GAOKAO_PROXY__STATIC_PROXIES=[]
GAOKAO_PROXY__USE_FREEPROXY=true
GAOKAO_PROXY__REFRESH_INTERVAL_MIN=30

# Crawl settings
GAOKAO_CRAWL__CONCURRENCY=2
GAOKAO_CRAWL__CONCURRENCY_PER_DOMAIN=1
GAOKAO_CRAWL__BASE_DELAY=1.0
GAOKAO_CRAWL__JITTER_RATIO=0.5
GAOKAO_CRAWL__BATCH_SIZE=500
GAOKAO_CRAWL__YEAR_START=2015
GAOKAO_CRAWL__SPIDER_TIMEOUT=14400

# Scheduler (Asia/Shanghai)
GAOKAO_SCHEDULE__CRON="0 23 * * *"
GAOKAO_SCHEDULE__MODE=incremental
GAOKAO_SCHEDULE__MAX_CONCURRENT_TYPES=3

# OpenAI Vision API
OPENAI_API_BASE=https://api.openai.com/v1
OPENAI_API_KEY=sk-your-api-key-here
OPENAI_HEALTH_MODEL=gpt-5.4
OPENAI_VISION_MODEL=gpt-5.4

# MinIO / S3 Storage (for image upload instead of base64)
S3_ENDPOINT_URL=http://minio:9000
S3_PUBLIC_URL=http://YOUR_VPS_PUBLIC_IP/minio-s3
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET_NAME=gaokao-screenshots
S3_PRESIGN_EXPIRES=3600
